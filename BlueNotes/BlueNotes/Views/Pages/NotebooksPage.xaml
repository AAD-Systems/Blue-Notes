<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BlueNotes.ViewModels"
             xmlns:models="clr-namespace:BlueNotes.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BlueNotes.Views.Pages.NotebooksPage"
             x:DataType="vm:NotebooksViewModel"
             Title="Cadernos">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding AddNotebookCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*">
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center" HorizontalOptions="Center"/>

        <VerticalStackLayout IsVisible="{Binding IsEmpty}" VerticalOptions="Center" Spacing="10">
            <Label Text="📓" FontSize="60" HorizontalOptions="Center"/>
            <Label Text="Nenhum caderno ainda" Style="{StaticResource H2}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <CollectionView ItemsSource="{Binding Items}" Margin="16" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Notebook">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Renomear" BackgroundColor="{StaticResource AccentDark}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                             Path=BindingContext.RenameCommand}"
                                           CommandParameter="{Binding .}"/>
                                <SwipeItem Text="Excluir" BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                             Path=BindingContext.DeleteCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Style="{StaticResource Card}">
                            <Grid ColumnDefinitions="52,*,Auto">
                                <Frame Grid.Column="0" CornerRadius="14" BackgroundColor="{Binding Color}"
                                       WidthRequest="48" HeightRequest="48" Padding="0" HasShadow="False">
                                    <Label Text="{Binding Icon}" FontSize="24"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontFamily="NunitoBold" FontSize="16"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <Label Text="{Binding NoteCount, StringFormat='{0} notas'}"
                                           Style="{StaticResource Caption}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="22"
                                       TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>

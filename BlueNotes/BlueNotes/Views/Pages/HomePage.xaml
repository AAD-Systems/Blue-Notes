<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BlueNotes.ViewModels"
             xmlns:models="clr-namespace:BlueNotes.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BlueNotes.Views.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="Blue Notes">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadCommand}" />
    </ContentPage.Behaviors>

    <!-- ── Root Grid ────────────────────────────────────────────── -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ───────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="20,16,20,8" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0">
                <Label Text="Minhas Notas" Style="{StaticResource H1}" />
                <Label Text="{Binding RecentNotes.Count, StringFormat='{0} notas'}"
                       Style="{StaticResource Caption}" Margin="0,2,0,0"/>
            </VerticalStackLayout>
            <ImageButton Grid.Column="1" Source="icon_search.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="{StaticResource SurfaceElevated}"
                         CornerRadius="20" Padding="10"
                         Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}},
                                           Path=GoToAsync}"
                         CommandParameter="//SearchPage" />
        </Grid>

        <!-- ── Loading ──────────────────────────────────────────── -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- ── Empty State ──────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
            <Label Text="📝" FontSize="64" HorizontalOptions="Center"/>
            <Label Text="Nenhuma nota ainda" Style="{StaticResource H2}"
                   HorizontalOptions="Center" />
            <Label Text="Toque em + para criar sua primeira nota"
                   Style="{StaticResource Body}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- ── Scrollable Content ───────────────────────────────── -->
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadCommand}"
                     IsVisible="{Binding IsNotBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="16,0,16,80" Spacing="0">

                    <!-- Pinned Section -->
                    <Label Text="📌 Fixadas" Style="{StaticResource H2}"
                           IsVisible="{Binding HasPinned}" Margin="4,8,0,10"/>
                    <CollectionView ItemsSource="{Binding PinnedNotes}"
                                    IsVisible="{Binding HasPinned}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Note">
                                <Frame Style="{StaticResource Card}"
                                       BackgroundColor="{Binding Color}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                              Path=BindingContext.OpenNoteCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontFamily="NunitoBold" FontSize="16"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="📌" FontSize="14" Margin="8,0,0,0"/>
                                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding PreviewBody}"
                                               Style="{StaticResource Body}"
                                               MaxLines="2" Margin="0,6,0,0"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Row="2" Grid.ColumnSpan="2"
                                               Text="{Binding UpdatedAtFormatted}"
                                               Style="{StaticResource Caption}"
                                               Margin="0,8,0,0"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Recent Section -->
                    <Label Text="Recentes" Style="{StaticResource H2}"
                           Margin="4,12,0,10"/>
                    <CollectionView ItemsSource="{Binding RecentNotes}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Note">
                                <SwipeView>
                                    <!-- Swipe Left → Archive -->
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Arquivar" IconImageSource="icon_archive.png"
                                                       BackgroundColor="{StaticResource ArchiveColor}"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                         Path=BindingContext.ArchiveNoteCommand}"
                                                       CommandParameter="{Binding .}"/>
                                            <SwipeItem Text="Excluir" IconImageSource="icon_trash.png"
                                                       BackgroundColor="{StaticResource Danger}"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                         Path=BindingContext.DeleteNoteCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <!-- Swipe Right → Pin -->
                                    <SwipeView.LeftItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Fixar" IconImageSource="icon_pin.png"
                                                       BackgroundColor="{StaticResource AccentDark}"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                         Path=BindingContext.TogglePinCommand}"
                                                       CommandParameter="{Binding .}"/>
                                        </SwipeItems>
                                    </SwipeView.LeftItems>

                                    <Frame Style="{StaticResource Card}"
                                           BackgroundColor="{Binding Color}">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                                  Path=BindingContext.OpenNoteCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Frame.GestureRecognizers>
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{Binding Title}"
                                                       FontFamily="NunitoBold" FontSize="16"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Grid.Column="1" Text="🔒" FontSize="13"
                                                       IsVisible="{Binding IsLocked}" Margin="6,0,0,0"/>
                                            </Grid>
                                            <Label Grid.Row="1" Text="{Binding PreviewBody}"
                                                   Style="{StaticResource Body}"
                                                   MaxLines="3" Margin="0,6,0,0"
                                                   LineBreakMode="TailTruncation"/>
                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                                <Label Grid.Column="0"
                                                       Text="{Binding UpdatedAtFormatted}"
                                                       Style="{StaticResource Caption}"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding WordCount, StringFormat='{0} palavras'}"
                                                       Style="{StaticResource Caption}"/>
                                            </Grid>
                                        </Grid>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ── FAB ──────────────────────────────────────────────── -->
        <Button Grid.Row="2" Text="+" Style="{StaticResource FAB}"
                Command="{Binding NewNoteCommand}"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,24" />

    </Grid>
</ContentPage>

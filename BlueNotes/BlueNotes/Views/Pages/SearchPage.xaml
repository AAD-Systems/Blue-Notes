<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BlueNotes.ViewModels"
             xmlns:models="clr-namespace:BlueNotes.Models"
             x:Class="BlueNotes.Views.Pages.SearchPage"
             x:DataType="vm:SearchViewModel"
             Title="Busca">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search Bar -->
        <SearchBar Grid.Row="0" Margin="16,12"
                   Text="{Binding Query}"
                   Placeholder="Buscar notas, títulos, conteúdo..."
                   BackgroundColor="{StaticResource SurfaceElevated}" />

        <!-- Recent Queries -->
        <VerticalStackLayout Grid.Row="1" IsVisible="{Binding NoResults}" Margin="16,0">
            <Label Text="Buscas recentes" Style="{StaticResource Caption}" Margin="0,0,0,8"/>
            <CollectionView ItemsSource="{Binding RecentQueries}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Frame Style="{StaticResource TagChip}">
                            <Label Text="{Binding .}" FontSize="12"
                                   TextColor="{StaticResource TextSecondary}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.UseRecentQueryCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- No Results -->
        <VerticalStackLayout Grid.Row="2" IsVisible="{Binding NoResults}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Label Text="🔍" FontSize="56" HorizontalOptions="Center"/>
            <Label Text="Nenhum resultado" Style="{StaticResource H2}" HorizontalOptions="Center"/>
            <Label Text="Tente outras palavras-chave" Style="{StaticResource Body}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Results List -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Results}"
                        SelectionMode="None" Margin="16,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Note">
                    <Frame Style="{StaticResource Card}" BackgroundColor="{Binding Color}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                  Path=BindingContext.OpenNoteCommand}"
                                CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}" FontFamily="NunitoBold" FontSize="15"
                                   TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding PreviewBody}" Style="{StaticResource Body}"
                                   MaxLines="2" LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding UpdatedAtFormatted}" Style="{StaticResource Caption}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
